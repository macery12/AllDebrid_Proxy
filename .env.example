##############################################
# Core Configuration
##############################################
# IMPORTANT: WORKER_API_KEY is required for frontend-to-backend authentication
# Change from "change-me" to a secure random string (minimum 8 characters)
# This key must match between frontend and API services
WORKER_API_KEY=change-me
# Note: User authentication is now database-backed.
# On first startup, you will be prompted to create an admin account.
# Uses the Docker Compose service name ("api") so it works on any port mapping.
WORKER_BASE_URL=http://api:8080
FLASK_SECRET=change-me

##############################################
# AllDebrid Settings
##############################################
ALLDEBRID_API_KEY=change-me
ALLDEBRID_AGENT=Generic-PC

##############################################
# Storage Configuration
##############################################
# Host path that is bind-mounted into every container as /srv/storage.
# Change STORAGE_PATH if you want data stored somewhere other than /srv/storage.
STORAGE_PATH=/srv/storage
STORAGE_ROOT=/srv/storage
LOW_SPACE_FLOOR_GB=10

##############################################
# ARIA2C Settings
##############################################
ARIA2_RPC_URL=http://aria2:16800/jsonrpc
ARIA2_RPC_SECRET=change-me
ARIA2_SPLITS=4
PER_TASK_MAX_ACTIVE=2

##############################################
# PostgreSQL Database
##############################################
POSTGRES_USER=alldebrid
POSTGRES_PASSWORD=alldebrid
POSTGRES_DB=alldebrid
DATABASE_URL=postgresql+psycopg2://alldebrid:alldebrid@db:5432/alldebrid

##############################################
# Redis Cache
##############################################
REDIS_URL=redis://redis:6379/0

##############################################
# Ports
# These control the HOST-side port mapping in docker-compose.yml.
# If you change API_PORT or FRONTEND_PORT here, update debrid.conf to match.
##############################################
API_PORT=9731
FRONTEND_PORT=9732
ARIA2_RPC_PORT=16800
