##############################################
# Core Configuration
##############################################
# IMPORTANT: WORKER_API_KEY is required for frontend-to-backend authentication
# Change from "change-me" to a secure random string (minimum 8 characters)
# This key must match between frontend and API services
WORKER_API_KEY=change-me
# Note: User authentication is now database-backed.
# On first startup, you will be prompted to create an admin account.
# Uses the Docker Compose *service* name ("api"), not the container_name ("proxy_api").
# Docker Compose resolves service names as hostnames on the shared network.
WORKER_BASE_URL=http://api:8080
FLASK_SECRET=change-me

##############################################
# AllDebrid Settings
##############################################
ALLDEBRID_API_KEY=change-me
ALLDEBRID_AGENT=Generic-PC

##############################################
# Storage Configuration
##############################################
# Host path that is bind-mounted into every container as /srv/storage.
# Change STORAGE_PATH if you want data stored somewhere other than /srv/storage.
STORAGE_PATH=/srv/storage
STORAGE_ROOT=/srv/storage
LOW_SPACE_FLOOR_GB=10

##############################################
# ARIA2C Settings
##############################################
ARIA2_RPC_URL=http://aria2:16800/jsonrpc
ARIA2_RPC_SECRET=change-me
ARIA2_SPLITS=4
PER_TASK_MAX_ACTIVE=2

##############################################
# PostgreSQL Database
##############################################
POSTGRES_USER=alldebrid
POSTGRES_PASSWORD=alldebrid
POSTGRES_DB=alldebrid
DATABASE_URL=postgresql+psycopg2://alldebrid:alldebrid@db:5432/alldebrid

##############################################
# Redis Cache
##############################################
REDIS_URL=redis://redis:6379/0

##############################################
# Ports
# These control the HOST-side port mapping in docker-compose.yml.
# If you change API_PORT or FRONTEND_PORT here, update debrid.conf to match.
##############################################
API_PORT=9731
FRONTEND_PORT=9732
ARIA2_RPC_PORT=16800

##############################################
# CORS
# Comma-separated list of allowed cross-origin request origins.
# Defaults to deny-all (empty). Explicit opt-in required.
# Example: CORS_ORIGINS=https://app.example.com,https://other.example.com
##############################################
CORS_ORIGINS=

##############################################
# Transcoding (ffmpeg-based smart video player)
# FFMPEG_BIN: path to the ffmpeg binary (default: "ffmpeg" on $PATH)
# MAX_CONCURRENT_TRANSCODES: max simultaneous transcode jobs (default: 2)
# TRANSCODE_MAX_LOAD: refuse new transcode jobs if 1-min load avg exceeds this (default: 3.0)
# TRANSCODE_TTL_HOURS: how long to keep completed HLS output before cleanup (default: 4)
# FFMPEG_THREADS: max CPU threads per ffmpeg process (0 = auto/unlimited, default: 0)
#                 Set to e.g. 6 or 12 to cap CPU usage on busy servers.
# HEARTBEAT_TIMEOUT: seconds without a client heartbeat before killing ffmpeg (default: 45)
#                    The player page sends a ping every 15 s; this fires when the
#                    browser navigates away or the tab is closed.
##############################################
FFMPEG_BIN=ffmpeg
MAX_CONCURRENT_TRANSCODES=2
TRANSCODE_MAX_LOAD=10.0
TRANSCODE_TTL_HOURS=4
FFMPEG_THREADS=0
HEARTBEAT_TIMEOUT=45
